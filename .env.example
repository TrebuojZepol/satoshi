# --- Bitcoin chain ---
# mock = in-app block clock + mock JSON-RPC (default)
# rpc  = Bitcoin Core JSON-RPC (server-side only; never expose credentials to the browser)
BITVAULT_BITCOIN_MODE=mock

# Network label for PSBT helpers: regtest | testnet | mainnet (default regtest)
BITVAULT_BITCOIN_NETWORK=regtest

# Optional funded UTXO for dev PSBT build (POST /api/batch/settlement-psbt).
# JSON: { "txid": "64-hex", "vout": 0, "value": 200000, "wif": "..." }
# WIF in env is dev-only — never ship production secrets this way.
BITVAULT_PSBT_UTXO=

# Full URL to bitcoind, e.g. http://127.0.0.1:18443 for local regtest
BITCOIN_RPC_URL=

BITCOIN_RPC_USER=
BITCOIN_RPC_PASSWORD=

# When set, POST /api/bitcoin/rpc requires Authorization: Bearer <secret> or x-satoshifi-rpc-secret (legacy: x-bitvault-rpc-secret).
# Strongly recommended in production whenever the RPC proxy is reachable.
BITVAULT_RPC_PROXY_SECRET=

# --- Pricing / oracle (batch limits & vault marks) ---
# mock       = deterministic sin wave (offline-safe)
# coingecko  = live BTC/USD (server fetch; falls back to mock if request fails)
BITVAULT_PRICE_SOURCE=mock

# --- Database ---
# Optional override for SQLite path (tests use this)
# BV_DB_PATH=./data/satoshifi.db

# When set, the app uses PostgreSQL (Drizzle + pg). Await initDatabase() runs from Next instrumentation on startup.
# Example (docker compose postgres service): postgresql://satoshifi:satoshifi@127.0.0.1:5432/satoshifi
# DATABASE_URL=

# Omit DATABASE_URL for file SQLite (default local dev).
# Postgres DDL is applied from the committed folder drizzle/postgres (see README).
